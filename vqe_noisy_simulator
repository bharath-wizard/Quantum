import numpy as np
import matplotlib.pyplot as plt
from scipy.optimize import minimize

from qiskit.quantum_info import SparsePauliOp
from qiskit.circuit.library import n_local
from qiskit import transpile

from qiskit_aer.noise import NoiseModel, depolarizing_error, ReadoutError
from qiskit_aer.primitives import EstimatorV2 as AerEstimatorV2


hamiltonian = SparsePauliOp.from_list([
    ("ZZ", -1.052373245772859),
    ("ZI", 0.39793742484318045),
    ("IZ", -0.39793742484318045),
    ("XX", -0.01128010425623538)
])

E0_exact = -1.137270174


# Updated replacement for deprecated TwoLocal
ansatz = n_local(
    num_qubits=2,
    rotation_blocks=["ry", "rz"],
    entanglement_blocks="cx",
    reps=2,
    entanglement="full"
)

transpiled_ansatz = transpile(
    ansatz,
    basis_gates=["rx", "ry", "rz", "cx"]
)

print(ansatz.draw())
print("Number of parameters:", ansatz.num_parameters)
print("Circuit depth:", ansatz.depth())


def build_noise_model(p_gate, p_readout):
    noise_model = NoiseModel()

    single_error = depolarizing_error(p_gate, 1)
    noise_model.add_all_qubit_quantum_error(single_error, ["ry", "rz"])

    two_error = depolarizing_error(10 * p_gate, 2)
    noise_model.add_all_qubit_quantum_error(two_error, ["cx"])

    readout_error = ReadoutError([
        [1 - p_readout, p_readout],
        [p_readout, 1 - p_readout]
    ])
    noise_model.add_all_qubit_readout_error(readout_error)

    return noise_model


def run_noisy_vqe(noise_level, n_iter=300):
    noise_model = build_noise_model(
        p_gate=noise_level,
        p_readout=noise_level / 2
    )

    estimator = AerEstimatorV2(
        options={
            "backend_options": {
                "noise_model": noise_model
            },
            "run_options": {
                "shots": 4096
            }
        }
    )

    history = []

    def cost_fn(params):
        bound_circuit = transpiled_ansatz.assign_parameters(params)

        pub = (bound_circuit, hamiltonian)

        result = estimator.run([pub]).result()
        energy = float(result[0].data.evs)

        history.append(energy)
        return energy

    np.random.seed(7)
    theta0 = np.random.uniform(
        -np.pi,
        np.pi,
        ansatz.num_parameters
    )

    result = minimize(
        cost_fn,
        theta0,
        method="COBYLA",
        options={
            "maxiter": n_iter,
            "rhobeg": 0.5
        }
    )

    return result.fun, history


noise_levels = [0.0, 0.02, 0.05, 0.10]

plt.figure(figsize=(10, 5))

for noise_level in noise_levels:
    final_energy, history = run_noisy_vqe(noise_level, n_iter=300)

    label = "noiseless" if noise_level == 0 else f"noise = {noise_level:.0%}"

    plt.plot(
        history,
        linewidth=1.2,
        alpha=0.8,
        label=label
    )

    print(f"{label}: final energy = {final_energy:.6f}")


plt.axhline(
    E0_exact,
    color="black",
    linestyle="--",
    linewidth=1.5,
    label=f"Exact E0 = {E0_exact:.4f}"
)

plt.xlabel("Optimizer iteration")
plt.ylabel("Energy expectation value")
plt.title("VQE Convergence Under Different Noise Levels")
plt.legend()
plt.grid(True, alpha=0.3)
plt.tight_layout()
plt.show()